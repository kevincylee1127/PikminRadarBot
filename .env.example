# ─────────────────────────────────────────────
# .env.example — 環境變數範本
# 複製此檔案並改名為 .env，填入真實金鑰後使用
# 注意：.env 不可 commit 至版本控制（請加入 .gitignore）
# ─────────────────────────────────────────────

# LINE Messaging API 金鑰
# 取得位置：LINE Developers Console → 你的 Provider → Channel → Basic settings
LINE_CHANNEL_SECRET=your_channel_secret_here
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here

# Overpass API 端點（可換鏡像站以提升速度）
# 官方：https://overpass-api.de/api/interpreter
# 法國鏡像：https://overpass.openstreetmap.fr/api/interpreter
OVERPASS_URL=https://overpass-api.de/api/interpreter

# 查詢半徑（公尺），預設 500
SEARCH_RADIUS_M=500

# Overpass 請求逾時（秒）
OVERPASS_TIMEOUT_S=10.0

# 最大重試次數
OVERPASS_MAX_RETRIES=3
